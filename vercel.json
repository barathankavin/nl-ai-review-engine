{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/app/main.py",
      "routePrefix": "/_/backend",
      "framework": "fastapi",
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": [
        "backend/requirements.txt",
        "backend/Dockerfile",
        "backend/scripts/**",
        "backend/data/**",
        "**/__pycache__/**",
        "**/.venv/**"
      ]
    }
  }
}
