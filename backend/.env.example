GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=sqlite:///./data/reviews.db
SOURCE_CONFIG_PATH=./config/source_config.yaml
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
FRONTEND_URL=

# Railway: set GROQ_API_KEY in the service dashboard.
# DATABASE_URL defaults to sqlite:////app/data/reviews.db on Railway.
# Mount a volume at /app/data to persist the database across redeploys.
